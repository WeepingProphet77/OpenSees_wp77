{
  "name": "tessera",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "description": "Tessera — browser-based precast/prestressed concrete design (internal). FEA engine: forked OpenSees → WASM.",
  "scripts": {
    "dev": "vite",
    "build": "tsc -b && vite build",
    "preview": "vite preview",
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "tsc -b",
    "build:wasm": "bash fea/opensees/build-opensees.sh",
    "build:wasm:oracle": "bash fea/build.sh",
    "fea:smoke": "node fea/test/smoke.mjs"
  },
  "dependencies": {
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "jspdf": "^3.0.4",
    "lucide-react": "^1.21.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "tailwind-merge": "^3.6.0",
    "zod": "^4.0.0",
    "zustand": "^5.0.0"
  },
  "devDependencies": {
    "@tailwindcss/vite": "^4.3.0",
    "@types/node": "^22.0.0",
    "@types/react": "^18.3.12",
    "@types/react-dom": "^18.3.1",
    "@vitejs/plugin-react": "^5.1.0",
    "tailwindcss": "^4.3.0",
    "typescript": "^5.7.0",
    "vite": "^7.3.0",
    "vitest": "^4.1.0"
  }
}
